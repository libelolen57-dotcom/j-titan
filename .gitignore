# ──────────────────────────────────────────────────────────────────
# ホームディレクトリを git 管理するため、まず全て除外し、
# 必要なプロジェクトファイルだけをホワイトリストで許可する
# ──────────────────────────────────────────────────────────────────

# デフォルト: ルート直下のすべてを無視
/*

# ── プロジェクトファイル（許可） ────────────────────────────────────
!.gitignore
!.github
!j_titan_engine.py
!screen_signals.py
!fetch_master_data.py
!fetch_japan_data.py
!advanced_backtest.py

# 資産ログ・パラメータ（自動保存対象）
!portfolio.json
!portfolio_us.json

# 戦略比較スクリプト
!compare_strategies.py

# ── BTC エアトレードシステム ─────────────────────────────────────
!btc_paper_trade.py
!btc_dashboard.py
!btc_history.py
!btc_strategy_v5.py
!btc_strategy_v6.py
!btc_strategy_v7.py
!btc_wfa.py
!btc_portfolio.json
!btc_log
!btc_log/**

# 株価データ（GitHub Actions が参照）
!data
!data/**

# バックテスト・資産曲線グラフ
!output
!output/**

# GitHub Pages ダッシュボード
!index.html

# ── Python キャッシュ（data/ output/ 内でも除外） ─────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.Python
